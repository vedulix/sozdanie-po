<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Avalonia_Lab03_CustomControls.Controls.ColorPicker">

  <!-- Упражнение 1: Композитный элемент управления — выбор цвета через три ползунка R/G/B -->
  <StackPanel Spacing="8" Margin="10">

    <!-- Ползунок красного канала -->
    <StackPanel Orientation="Horizontal" Spacing="8">
      <TextBlock Text="R:" Foreground="Red" VerticalAlignment="Center" Width="20"/>
      <Slider x:Name="SliderR" Minimum="0" Maximum="255" Value="0" Width="280"
              TickFrequency="32" IsSnapToTickEnabled="False"/>
      <TextBlock x:Name="LblRValue" Text="0" VerticalAlignment="Center" Width="30"/>
    </StackPanel>

    <!-- Ползунок зелёного канала -->
    <StackPanel Orientation="Horizontal" Spacing="8">
      <TextBlock Text="G:" Foreground="Green" VerticalAlignment="Center" Width="20"/>
      <Slider x:Name="SliderG" Minimum="0" Maximum="255" Value="0" Width="280"
              TickFrequency="32" IsSnapToTickEnabled="False"/>
      <TextBlock x:Name="LblGValue" Text="0" VerticalAlignment="Center" Width="30"/>
    </StackPanel>

    <!-- Ползунок синего канала -->
    <StackPanel Orientation="Horizontal" Spacing="8">
      <TextBlock Text="B:" Foreground="Blue" VerticalAlignment="Center" Width="20"/>
      <Slider x:Name="SliderB" Minimum="0" Maximum="255" Value="0" Width="280"
              TickFrequency="32" IsSnapToTickEnabled="False"/>
      <TextBlock x:Name="LblBValue" Text="0" VerticalAlignment="Center" Width="30"/>
    </StackPanel>

    <!-- Панель предпросмотра выбранного цвета и hex-код -->
    <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,5,0,0">
      <Border x:Name="PreviewBorder" Width="200" Height="40"
              BorderBrush="Gray" BorderThickness="1"
              Background="Black"/>
      <TextBlock x:Name="LblHex" Text="#000000" VerticalAlignment="Center"/>
    </StackPanel>

  </StackPanel>
</UserControl>
