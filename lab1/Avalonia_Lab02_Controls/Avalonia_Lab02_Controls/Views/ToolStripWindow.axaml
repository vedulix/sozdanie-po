<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Avalonia_Lab02_Controls.Views.ToolStripWindow"
        Title="ToolStrip (панель инструментов)"
        Width="450" Height="300"
        WindowStartupLocation="CenterScreen">
    <!-- Упражнение 3: Панель инструментов (аналог ToolStrip) -->
    <DockPanel>
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal"
                    Spacing="5" Margin="5"
                    Background="#F0F0F0">
            <Button Content="Создать" Click="OnNew"/>
            <Button Content="Открыть" Click="OnOpen"/>
            <Button Content="Сохранить" Click="OnSave"/>
        </StackPanel>

        <TextBlock Text="Нажмите на кнопки панели инструментов выше."
                   FontSize="14"
                   Margin="20,20"/>
    </DockPanel>
</Window>
