<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Avalonia_Lab02_Controls.Views.StatusStripWindow"
        Title="StatusBar + Timer"
        Width="450" Height="250"
        WindowStartupLocation="CenterScreen">
    <!-- Упражнение 4: Строка состояния с таймером, обновляющим время каждую секунду -->
    <DockPanel>
        <Border DockPanel.Dock="Bottom" Background="#F0F0F0"
                Padding="10,5" BorderThickness="0,1,0,0"
                BorderBrush="#CCCCCC">
            <TextBlock x:Name="LblStatus" FontSize="12"/>
        </Border>

        <TextBlock Text="Текущие дата и время обновляются&#10;каждую секунду в строке состояния."
                   FontSize="14"
                   Margin="20,30"/>
    </DockPanel>
</Window>
