<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Avalonia_Lab02_Controls.Views"
        x:Class="Avalonia_Lab02_Controls.Views.AddressBookWindow"
        Title="Адресная книга"
        Width="560" Height="440"
        WindowStartupLocation="CenterScreen">
    <!-- Упражнение 9: Адресная книга с таблицей (аналог DataGridView) -->
    <DockPanel Margin="20">
        <!-- Панель ввода и кнопки внизу -->
        <StackPanel DockPanel.Dock="Bottom" Spacing="10" Margin="0,10,0,0">
            <Grid ColumnDefinitions="*,10,*,10,*">
                <TextBox x:Name="TxtName" Watermark="Имя" Grid.Column="0"/>
                <TextBox x:Name="TxtPhone" Watermark="Телефон" Grid.Column="2"/>
                <TextBox x:Name="TxtEmail" Watermark="Email" Grid.Column="4"/>
            </Grid>
            <StackPanel Orientation="Horizontal" Spacing="10">
                <Button Content="Добавить" Width="100" Click="OnAdd"/>
                <Button Content="Удалить" Width="100" Click="OnDelete"/>
            </StackPanel>
        </StackPanel>

        <!-- Таблица контактов -->
        <DataGrid x:Name="DgContacts"
                  AutoGenerateColumns="False"
                  CanUserReorderColumns="False"
                  IsReadOnly="False"
                  SelectionMode="Single"
                  GridLinesVisibility="All">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Имя" Binding="{Binding Name, DataType=views:Contact}" Width="*"/>
                <DataGridTextColumn Header="Телефон" Binding="{Binding Phone, DataType=views:Contact}" Width="*"/>
                <DataGridTextColumn Header="Email" Binding="{Binding Email, DataType=views:Contact}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
