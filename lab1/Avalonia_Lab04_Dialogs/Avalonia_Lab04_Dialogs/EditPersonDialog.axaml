<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Avalonia_Lab04_Dialogs.EditPersonDialog"
        Title="Редактирование Person"
        Width="330" Height="200"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <!-- Упражнение 3: Модальный диалог для редактирования объекта Person -->
    <StackPanel Margin="15" Spacing="12">
        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" RowSpacing="10" ColumnSpacing="10">
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Имя:" VerticalAlignment="Center" />
            <TextBox Grid.Row="0" Grid.Column="1" Name="TxtName" />

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Возраст:" VerticalAlignment="Center" />
            <NumericUpDown Grid.Row="1" Grid.Column="1" Name="NudAge"
                           Minimum="1" Maximum="150" Value="18"
                           FormatString="0" />
        </Grid>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,10,0,0">
            <Button Name="BtnOk" Content="OK" Width="80" />
            <Button Name="BtnCancel" Content="Отмена" Width="80" />
        </StackPanel>
    </StackPanel>
</Window>
