<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Avalonia_Lab01_Forms.BaseWindow"
        Title="Базовая форма"
        Width="400" Height="300"
        WindowStartupLocation="CenterScreen"
        Background="Lavender">

    <!-- Упражнение 3: Базовая форма для наследования.
         Содержит элементы, доступные из дочерней формы. -->
    <StackPanel Margin="20" Spacing="15" x:Name="BasePanel">
        <TextBlock x:Name="LblBase"
                   Text="Это элемент базовой формы"
                   FontSize="16" FontWeight="Bold" />

        <Button x:Name="BtnBase"
                Content="Кнопка базовой формы"
                Width="200" Height="35"
                HorizontalAlignment="Left"
                Click="OnBaseButtonClick" />
    </StackPanel>
</Window>
