<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Avalonia_Lab01_Forms.MainWindow"
        Title="Лаб 1 - Формы"
        Width="500" Height="400"
        WindowStartupLocation="CenterScreen"
        Background="LightBlue">

    <!-- Упражнение 1: Главная форма с кнопками для открытия остальных окон -->
    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,20,0,0" Spacing="15">

        <!-- Приветственная надпись -->
        <TextBlock Text="Добро пожаловать!"
                   FontSize="24" FontWeight="Bold"
                   HorizontalAlignment="Center" />

        <!-- Кнопки для открытия окон -->
        <Button Content="Упр. 2: Круглая форма"
                Width="320" Height="35"
                HorizontalContentAlignment="Center"
                Click="OnRoundClick" />

        <Button Content="Упр. 3: Наследуемая форма"
                Width="320" Height="35"
                HorizontalContentAlignment="Center"
                Click="OnInheritedClick" />

        <Button Content="Упр. 4: MDI-приложение"
                Width="320" Height="35"
                HorizontalContentAlignment="Center"
                Click="OnMdiClick" />

        <Button Content="Упр. 5: Форма регистрации"
                Width="320" Height="35"
                HorizontalContentAlignment="Center"
                Click="OnRegistrationClick" />
    </StackPanel>
</Window>
