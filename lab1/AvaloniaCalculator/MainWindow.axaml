<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="AvaloniaCalculator.MainWindow"
        Title="Калькулятор"
        Width="320" Height="480"
        CanResize="False">

    <Grid RowDefinitions="Auto,*" Margin="8">
        <!-- Дисплей -->
        <TextBox Name="Display" Grid.Row="0"
                 FontSize="28" Height="50"
                 IsReadOnly="True" TextAlignment="Right"
                 Text="0" Margin="0,0,0,8"/>

        <!-- Кнопки -->
        <Grid Grid.Row="1" RowDefinitions="*,*,*,*,*,*" ColumnDefinitions="*,*,*,*" >

            <!-- Ряд 1: sqrt, x^2, 1/x, C -->
            <Button Grid.Row="0" Grid.Column="0" Content="√" Click="OnSqrt" Classes="fn"/>
            <Button Grid.Row="0" Grid.Column="1" Content="x²" Click="OnSquare" Classes="fn"/>
            <Button Grid.Row="0" Grid.Column="2" Content="1/x" Click="OnReciprocal" Classes="fn"/>
            <Button Grid.Row="0" Grid.Column="3" Content="C" Click="OnClear" Classes="clear"/>

            <!-- Ряд 2: 7, 8, 9, ÷ -->
            <Button Grid.Row="1" Grid.Column="0" Content="7" Click="OnNumber"/>
            <Button Grid.Row="1" Grid.Column="1" Content="8" Click="OnNumber"/>
            <Button Grid.Row="1" Grid.Column="2" Content="9" Click="OnNumber"/>
            <Button Grid.Row="1" Grid.Column="3" Content="÷" Click="OnOperator" Classes="op"/>

            <!-- Ряд 3: 4, 5, 6, × -->
            <Button Grid.Row="2" Grid.Column="0" Content="4" Click="OnNumber"/>
            <Button Grid.Row="2" Grid.Column="1" Content="5" Click="OnNumber"/>
            <Button Grid.Row="2" Grid.Column="2" Content="6" Click="OnNumber"/>
            <Button Grid.Row="2" Grid.Column="3" Content="×" Click="OnOperator" Classes="op"/>

            <!-- Ряд 4: 1, 2, 3, − -->
            <Button Grid.Row="3" Grid.Column="0" Content="1" Click="OnNumber"/>
            <Button Grid.Row="3" Grid.Column="1" Content="2" Click="OnNumber"/>
            <Button Grid.Row="3" Grid.Column="2" Content="3" Click="OnNumber"/>
            <Button Grid.Row="3" Grid.Column="3" Content="−" Click="OnOperator" Classes="op"/>

            <!-- Ряд 5: ±, 0, ., + -->
            <Button Grid.Row="4" Grid.Column="0" Content="±" Click="OnSign"/>
            <Button Grid.Row="4" Grid.Column="1" Content="0" Click="OnNumber"/>
            <Button Grid.Row="4" Grid.Column="2" Content="." Click="OnDecimal"/>
            <Button Grid.Row="4" Grid.Column="3" Content="+" Click="OnOperator" Classes="op"/>

            <!-- Ряд 6: n!, ³√, ^, = -->
            <Button Grid.Row="5" Grid.Column="0" Content="n!" Click="OnFactorial" Classes="fn"/>
            <Button Grid.Row="5" Grid.Column="1" Content="³√" Click="OnCubeRoot" Classes="fn"/>
            <Button Grid.Row="5" Grid.Column="2" Content="^" Click="OnOperator" Classes="op"/>
            <Button Grid.Row="5" Grid.Column="3" Content="=" Click="OnEqual" Classes="eq"/>
        </Grid>
    </Grid>

    <Window.Styles>
        <Style Selector="Button">
            <Setter Property="Margin" Value="2"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.op">
            <Setter Property="Background" Value="#FF8C00"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.eq">
            <Setter Property="Background" Value="#0078D7"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.fn">
            <Setter Property="Background" Value="#555555"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.clear">
            <Setter Property="Background" Value="#CC3333"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </Window.Styles>
</Window>
