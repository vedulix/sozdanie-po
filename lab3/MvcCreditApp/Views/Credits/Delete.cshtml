@model MvcCreditApp.Models.Credit

@{
    ViewData["Title"] = "Удалить кредит";
}

<h2>Удалить кредит</h2>

<h3>Вы уверены, что хотите удалить этот кредит?</h3>
<div>
    <dl class="row">
        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Head)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Head)</dd>

        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Period)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Period)</dd>

        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Sum)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Sum)</dd>

        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Procent)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Procent)</dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="CreditId" />
        <input type="submit" value="Удалить" class="btn btn-danger" /> |
        <a asp-action="Index">К списку</a>
    </form>
</div>
