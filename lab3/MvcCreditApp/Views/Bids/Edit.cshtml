@model MvcCreditApp.Models.Bid

@{
    ViewData["Title"] = "Редактировать заявку";
}

<h2>Редактировать заявку</h2>

<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="BidId" />
            <div class="form-group">
                <label asp-for="Name" class="control-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="CreditHead" class="control-label"></label>
                <input asp-for="CreditHead" class="form-control" />
                <span asp-validation-for="CreditHead" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="bidDate" class="control-label"></label>
                <input asp-for="bidDate" class="form-control" />
                <span asp-validation-for="bidDate" class="text-danger"></span>
            </div>
            <div class="form-group mt-2">
                <input type="submit" value="Сохранить" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">К списку</a>
</div>
